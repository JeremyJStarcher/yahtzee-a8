10 REM SAVE "D:ATOM.BAS":LIST "D:ATOM.BAS":GR.0›100 REM SAVE "D:ATOS.BAS":LIST "D:ATOS.LST":LIST "H:ATOS.LST":GR.0›110 REM RENUM 100,100,10:GR.0›120 DIM A(200)›130 POKE 82,0:REM USE THE FULL 40 COLUMNS›140 VRAM=DPEEK(88):REM START OF VIDEO RAM›150 GRAPHICS 0›160 FOR I=0 TO 127›170   PRINT "";›180   PRINT CHR$(I);›190 NEXT I›200 FOR I=0 TO 127›210   V=PEEK(VRAM+I)›220   A(I)=V›230   REM PRINT V;" ";›240 NEXT I›250 OPEN #1,8,0,"H:CODE.TXT"›260 FOR I=0 TO 127›270   V=A(I)›280   PRINT #1;V›290 NEXT I›300 CLOSE #1›